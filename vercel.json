{
  "installCommand": "npm install --prefer-offline=false",
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/images/(.*\\.mp4)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
